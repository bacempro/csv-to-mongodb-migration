# Copy this file to .env and fill in real values. .env is gitignored.

# Mongo connection & collection
MONGO_ROOT_USER=root
MONGO_ROOT_PASSWORD=change_me_root
MONGO_APP_USER=app_ingestor
MONGO_APP_PASSWORD=change_me_app

MONGO_DB=healthcare
MONGO_COLLECTION=patients

# Data — file name inside ./data (mounted read-only into the loader)
CSV_FILENAME=healthcare_dataset_subset.csv

# Logging / reporting
REPORT_PATH=/reports/report.txt
LOG_LEVEL=INFO
